# Copie para .env (ou exporte no terminal) e preencha.

# Sessão Flask (troque em produção)
ARQUIVO01_SECRET=uma-chave-longa-aleatoria

# E-mail (opcional): boas-vindas e avisos
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@seu-dominio.com

# Mercado Pago — Checkout Pro (criar em https://www.mercadopago.com.br/developers/ )
MERCADOPAGO_ACCESS_TOKEN=
# 1 = usar sandbox (link de teste) quando existir; 0 = priorizar init_point de produção
MERCADOPAGO_SANDBOX=1

# URL pública do site (back_urls e webhook). Ex.: http://127.0.0.1:8000  ou  https://seu-dominio.com
PUBLIC_BASE_URL=http://127.0.0.1:8000
