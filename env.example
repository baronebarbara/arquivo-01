# Copie para .env (ou exporte no terminal) e preencha.

# Sessão Flask (troque em produção)
ARQUIVO01_SECRET=uma-chave-longa-aleatoria

# Página /admin.html — cadastro de peças (gere outra chave longa, só sua)
ARQUIVO01_ADMIN_KEY=

# E-mail (OBRIGATÓRIO para enviar algo): sem estas variáveis, cadastro e pedido NÃO disparam e-mail.
# Render: Environment → adicione cada variável abaixo.
#
# Gmail: ative verificação em 2 etapas e crie "Senha de app" em
#   https://myaccount.google.com/apppasswords — use essa senha em SMTP_PASS (não é a senha da conta).
# SMTP_USER=seu@gmail.com
# SMTP_PASS=senha-de-app-16-caracteres
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM=seu@gmail.com
# Opcional: cópia oculta para você (loja) em todo e-mail ao cliente
# SMTP_BCC=sua-loja@gmail.com
#
# Se a porta 587 falhar no provedor, tente SSL:
# SMTP_SSL=1
# SMTP_PORT=465

# Mercado Pago — Checkout Pro (criar em https://www.mercadopago.com.br/developers/ )
# Obrigatório no Render: copie o Access Token de produção ou teste; sem isso não há redirecionamento ao MP.
MERCADOPAGO_ACCESS_TOKEN=
# 1 = priorizar link sandbox; 0 = produção. Use 1 com credenciais de teste do MP.
MERCADOPAGO_SANDBOX=1

# URL pública do site (back_urls e webhook). No Render, coloque: https://SEU-SERVIÇO.onrender.com
# Se vazio, o servidor tenta deduzir; definir evita avisos do Mercado Pago.
PUBLIC_BASE_URL=http://127.0.0.1:8000
